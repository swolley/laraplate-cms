{
  "name": "swolley/laraplate-cms",
  "vendor": "swolley",
  "description": "Cms Module contains all the necessary functionalities for build up a new Cms system.",
  "version": "v1.22.6",
  "keywords": [
    "laravel",
    "laraplate",
    "cms"
  ],
  "authors": [
    {
      "name": "Swolley",
      "email": "myentity@inwind.it"
    }
  ],
  "license": "AGPL-3.0-or-later",
  "type": "laravel-module",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/swolley/license-compliance-checker.git",
      "no-api": true
    }
  ],
  "require": {
    "php": ">=8.5",
    "ext-gd": "*",
    "ext-exif": "*",
    "laravel/framework": "^12.0",
    "php-ffmpeg/php-ffmpeg": "^1.3",
    "spatie/laravel-medialibrary": "^11.12",
    "spatie/eloquent-sortable": "^4.4",
    "staudenmeir/laravel-adjacency-list": "^1.25"
  },
  "require-dev": {
    "swolley/license-compliance-checker": "dev-master",
    "laravel/pint": "^1.13",
    "nunomaduro/phpinsights": "^2.13",
    "peckphp/peck": "^0.1.3",
    "pestphp/pest": "^4.0",
    "pestphp/pest-plugin-laravel": "^4.0",
    "pestphp/pest-plugin-stressless": "^4.0",
    "pestphp/pest-plugin-type-coverage": "^4.0",
    "rector/rector": "^2.0",
    "orchestra/testbench": "^10.9",
    "larastan/larastan": "^3.9",
    "dg/bypass-finals": "^1.9",
    "driftingly/rector-laravel": "^2.2",
    "filament/filament": "^5.0"
  },
  "suggest": {
    "ext-imagick": "Advanced image processing"
  },
  "scripts": {
    "lint": [
      "rector",
      "pint --parallel",
      "php artisan ide-helper:generate",
      "php artisan ide-helper:models -MN",
      "php artisan ide-helper:meta"
    ],
    "check": "vendor/bin/phpstan analyse --memory-limit=2G -v",
    "fix": "vendor/bin/phpstan analyse --memory-limit=2G -v --fix",
    "refactor": "rector",
    "test:type-coverage": "pest --type-coverage --min=100",
    "test:typos": "peck",
    "test:lint": [
      "pint --parallel --test",
      "rector --dry-run"
    ],
    "test:standalone": "pest --compact tests/Unit tests/Feature/Controllers/LocationsControllerTest.php tests/Feature/Models/LocationTest.php",
    "test:integration": "pest --compact tests/Feature/Controllers/ContentsControllerTest.php tests/Feature/Helpers/HasDynamicContentsTest.php tests/Feature/Models/CategoryTest.php tests/Feature/Models/ContributorTest.php tests/Feature/Models/ContentTest.php tests/Feature/Models/TagTest.php tests/Feature/Services/PresetVersioningServiceTest.php",
    "test:unit": "@test:standalone",
    "test:types": "phpstan",
    "test:refactor": "rector",
    "test:licenses": "@php vendor/bin/check-licenses",
    "test": [
      "@test:type-coverage",
      "@test:standalone",
      "@test:lint",
      "@test:types",
      "@test:refactor",
      "@test:licenses"
    ],
    "update:requirements": [
      "composer bump",
      "npx npm-check-updates -u"
    ],
    "version": "v1.27.2",
    "version:silent": "./scripts/version.sh --silent --nointeractive",
    "version:major": "./scripts/version.sh major",
    "version:minor": "./scripts/version.sh minor",
    "version:patch": "./scripts/version.sh patch",
    "setup:hooks": "./scripts/setup-hooks.sh"
  },
  "extra": {
    "laravel": {
      "providers": [],
      "aliases": {}
    }
  },
  "autoload": {
    "psr-4": {
      "Modules\\Cms\\": "app/",
      "Modules\\Cms\\Database\\Factories\\": "database/factories/",
      "Modules\\Cms\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Modules\\Cms\\Tests\\Unit\\": "tests/Unit",
      "Modules\\Cms\\Tests\\Feature\\": "tests/Feature",
      "Modules\\Cms\\Tests\\Support\\": "tests/Support/"
    },
    "classmap": [
      "tests/TestCase.php",
      "tests/Support/User.php",
      "tests/Support/Database/Factories/UserFactory.php"
    ]
  },
  "config": {
    "allow-plugins": {
      "pestphp/pest-plugin": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  }
}