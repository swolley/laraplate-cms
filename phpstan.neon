includes:
    - vendor/larastan/larastan/extension.neon
    - vendor/nesbot/carbon/extension.neon
    - vendor/phpstan/phpstan/conf/bleedingEdge.neon

parameters:
    # Livello di analisi (0-9, max = 9)
    level: 5

    # PHPDoc from Larastan / relations is often wider than runtime; reduces false "always true" branches
    treatPhpDocTypesAsCertain: false

    tmpDir: /tmp/phpstan
    
    # Directory da analizzare (tests/ omitted: Pest expectations are not PHPStan-friendly without pestphp/extension)
    paths:
        - app/
        - config
        - database
        - routes
    
    # File da escludere
    excludePaths:
        - vendor/**
        - tests/Support/**
        # Stubs are loaded via bootstrapFiles; excluding avoids duplicate definitions and noise
        - tests/Stubs/**
        # These areas depend on the monolith (Core Filament utils, Elasticsearch client)
        - app/Filament/**
        - app/Analytics/**
        # Extends Core CrudController / CrudService — analyse with full app
        - app/Http/Controllers/ContentsController.php
        # Seeders extend Core Seeder / use Core models — analyse when Core is on the classpath
        - database/seeders/**
        # Blueprint fluent API vs framework version mismatches are noisy in packages
        - database/migrations/**

    # Ignora errori specifici
    ignoreErrors:
        # - '#Call to an undefined method [a-zA-Z0-9\\_]+::shouldReceive\(\)#'
        # - '#Call to an undefined method Illuminate\\Routing\\Route::name\(\).$#'
        # - '#Call to an undefined method Illuminate\\Routing\\Route::withoutMiddleware\(\).$#'
        # - '#Call to an undefined method Illuminate\\Routing\\Route::can\(\).$#'
        # - '#Call to an undefined method Illuminate\\Routing\\Route::where\(\).$#'
        # - '#Call to an undefined method Modules\\Core\\Http\\Requests\\CrudRequest::isJson\(\).$#'
        # - '#Call to an undefined method Modules\\Core\\Http\\Requests\\CrudRequest::json\(\).$#'
        # - '#Call to an undefined method Modules\\Core\\Http\\Requests\\CrudRequest::getRealMethod\(\).$#'
        # - '#Call to an undefined method Modules\\Core\\Grids\\Requests\\GridRequest::has\(\).$#'
        # - '#Call to an undefined method Modules\\Core\\Grids\\Requests\\GridRequest::get\(\).$#'
        # - '#Call to an undefined method Modules\\Core\\Grids\\Requests\\GridRequest::all\(\).$#'
        # - '#Call to an undefined method Modules\\Core\\Grids\\Requests\\GridRequest::getMethod\(\).$#'
        # - '#Call to an undefined static method Illuminate\\Database\\Eloquent\\Model::withTrashed\(\).$#'
        # - '#Call to an undefined static method Illuminate\\Database\\Eloquent\\Model::getTimestampColumns\(\).$#'
        # - '#Call to an undefined method Modules\\Core\Grids\\Casts\\GridRequestData|Modules\\Core\\Grids\\Requests\\GridRequest::getMethod\(\).$#'
        # - '#Call to an undefined method Illuminate\\Http\\Request::getMethod\(\).$#'
        # Ignora gli errori relativi ai metodi dei trait HasValidations e HasPermissions
        # - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::shouldSkipValidation\(\)#'
        # - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::validateWithRules\(\)#'
        # - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::getRules\(\)#'
        # - '#Call to an undefined method Illuminate\\Database\\Eloquent\\Model::getOperationRules\(\)#'
        # - '#Call to an undefined method Illuminate\\Foundation\\Auth\\User::isSuperAdmin\(\)#'
        # - '#Call to an undefined method Illuminate\\Foundation\\Auth\\User::hasPermission\(\)#'
        -
          message: "#Called 'env' outside of the config directory which returns null when the config is cached, use 'config'.$#"
          identifier: larastan.noEnvCallsOutsideOfConfig
          path: config/*
        # - '#Static call to instance method __construct\(\)#'
        - '#PHPDoc tag @mixin contains unknown class.*IdeHelper.*#'
        # Framework traits (Sortable, MediaLibrary) read these via reflection at runtime
        -
            identifier: property.onlyWritten
            path: app/Models/Content.php
        -
            identifier: property.onlyWritten
            path: app/Models/Pivot/Fieldable.php
        # Composite primary key vs parent string type (Laravel pivot)
        -
            identifier: property.defaultValue
            path: app/Models/Pivot/Categorizable.php
        # getPath() is ?string in HasPath; these models always return null
        -
            identifier: return.unusedType
            path: app/Models/Entity.php
        -
            identifier: return.unusedType
            path: app/Models/Tag.php
        -
            identifier: return.unusedType
            path: app/Models/Contributor.php
        # Singleton on abstract base: only concrete services call getInstance()
        -
            identifier: new.staticInAbstractClassStaticMethod
            path: app/Services/Contracts/AbstractGeocodingService.php
        -
            identifier: new.static
            path: app/Services/Contracts/AbstractGeocodingService.php
        -
            identifier: return.type
            path: app/Services/Contracts/AbstractGeocodingService.php
        # Spatie Media Library scopes not in generic Relation stubs
        -
            identifier: method.notFound
            path: app/Helpers/HasMedia.php
        # Laravel 12 relation generics (declaring model / pivot) vs Larastan stubs
        -
            identifier: generics.lessTypes
            path: app/Models
        -
            identifier: return.type
            path: app/Models
        -
            identifier: generics.lessTypes
            path: app/Helpers/HasDynamicContents.php
        -
            identifier: return.type
            path: app/Helpers/HasDynamicContents.php

    # Avoid noise when ignore patterns drift after refactors
    reportUnmatchedIgnoredErrors: false

    # Core stubs are loaded only via bootstrapFiles (not stubFiles) so PHPStan does not
    # type-check stub bodies against missing optional deps (e.g. Scout) in isolation.
    bootstrapFiles:
        - tests/bootstrap-stubs.php

    # Standalone package: Eloquent dynamic attrs; enable when @property blocks are complete
    checkModelProperties: false
    # Reduce false positives on dynamic Eloquent attributes and relations
    universalObjectCratesClasses:
        - Illuminate\Database\Eloquent\Model
    checkOctaneCompatibility: true
    noEnvCallsOutsideOfConfig: true
    checkModelAppends: true